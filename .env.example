# Database
FA_DATABASE_URL=postgresql+asyncpg://fa:fa@localhost:5432/freelance_assistant

# Redis
FA_REDIS_URL=redis://localhost:6379/0

# Telegram Bot
FA_TELEGRAM_BOT_TOKEN=your-bot-token-here
FA_TELEGRAM_OWNER_ID=123456789

# LLM
FA_LLM_BASE_URL=https://api.kblabs.ru/v1
FA_LLM_API_KEY=your-api-key-here
FA_LLM_MODEL=gpt-4o-mini

# Agent handoff
FA_AGENT_WEBHOOK_URL=
FA_AGENT_WEBHOOK_TOKEN=
FA_AGENT_WEBHOOK_TIMEOUT_SECONDS=20

# Enabled sources (JSON list): fl_ru, kwork, telegram
FA_ENABLED_SOURCES=["fl_ru"]

# Telegram Channels (for Telethon userbot, Phase 6)
# FA_TELEGRAM_API_ID=12345
# FA_TELEGRAM_API_HASH=abc123
# FA_TELEGRAM_CHANNELS=["@channel1","@channel2"]
